<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local 2dog packages (dotnet pack output of P:\2dog) for testing
         unreleased versions; published packages still come from nuget.org. -->
    <add key="2dog-local" value="P:\2dog\packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
